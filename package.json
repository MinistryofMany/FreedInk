{
	"name": "freedink",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"prebuild": "node --experimental-strip-types scripts/fetch-snark-artifacts.ts",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "node --experimental-strip-types scripts/migrate.ts",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"snark:fetch": "node --experimental-strip-types scripts/fetch-snark-artifacts.ts",
		"snark:check": "CHECK_ONLY=1 node --experimental-strip-types scripts/fetch-snark-artifacts.ts",
		"cleanup": "node --experimental-strip-types scripts/cleanup.ts",
		"backup": "node --experimental-strip-types scripts/backup.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"test:api": "npm run build && vitest run --project api",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:all": "npm run test:unit && npm run test:integration && npm run test:api && npm run test:e2e"
	},
	"devDependencies": {
		"@playwright/test": "^1.49.0",
		"@sveltejs/adapter-node": "^5.2.2",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@types/eslint": "^9.6.0",
		"@types/marked": "^5.0.2",
		"@types/nodemailer": "^6.4.17",
		"@types/web-push": "^3.6.4",
		"drizzle-kit": "^0.28.1",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.36.0",
		"globals": "^15.0.0",
		"jsdom": "^25.0.1",
		"pino-pretty": "^11.3.0",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"svelte": "^4.2.7",
		"svelte-check": "^3.6.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^5.0.3",
		"vitest": "^2.1.5"
	},
	"type": "module",
	"dependencies": {
		"@scure/bip39": "^1.5.0",
		"@semaphore-protocol/group": "^4.0.3",
		"@semaphore-protocol/identity": "^4.0.3",
		"@semaphore-protocol/proof": "^4.0.3",
		"@sentry/sveltekit": "^8.45.0",
		"@simplewebauthn/browser": "^11.0.0",
		"@simplewebauthn/server": "^11.0.0",
		"@simplewebauthn/types": "^11.0.0",
		"@tiptap/core": "^3.0.0",
		"@tiptap/extension-image": "^3.0.0",
		"@tiptap/extension-link": "^3.0.0",
		"@tiptap/extension-typography": "^3.0.0",
		"@tiptap/pm": "^3.0.0",
		"@tiptap/starter-kit": "^3.0.0",
		"dompurify": "^3.2.3",
		"drizzle-orm": "^0.36.4",
		"ethers": "^6.13.2",
		"isomorphic-dompurify": "^2.20.0",
		"marked": "^15.0.4",
		"nodemailer": "^6.9.16",
		"pino": "^9.5.0",
		"postgres": "^3.4.5",
		"sharp": "^0.33.5",
		"siwe": "^2.3.2",
		"svelte-i18n": "^4.0.1",
		"tiptap-markdown": "^0.9.0",
		"uuid": "^10.0.0",
		"web-push": "^3.6.7",
		"zod": "^3.23.8"
	}
}
