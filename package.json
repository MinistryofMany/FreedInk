{
	"name": "freedink",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"prebuild": "vite-node scripts/fetch-snark-artifacts.ts",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "vite-node scripts/migrate.ts",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"snark:fetch": "vite-node scripts/fetch-snark-artifacts.ts",
		"snark:check": "CHECK_ONLY=1 vite-node scripts/fetch-snark-artifacts.ts",
		"cleanup": "vite-node scripts/cleanup.ts",
		"backup": "vite-node scripts/backup.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"test:api": "npm run build && vitest run --project api",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:all": "npm run test:unit && npm run test:integration && npm run test:api && npm run test:e2e"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@playwright/test": "^1.49.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/eslint": "^9.6.0",
		"@types/marked": "^5.0.2",
		"@types/nodemailer": "^6.4.17",
		"@types/web-push": "^3.6.4",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^3.12.4",
		"globals": "^15.0.0",
		"jsdom": "^25.0.1",
		"pino-pretty": "^11.3.0",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^8.0.16",
		"vite-node": "^6.0.0",
		"vitest": "^4.1.8"
	},
	"type": "module",
	"dependencies": {
		"@cloudflare/blindrsa-ts": "^0.4.6",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/literata": "^5.2.8",
		"@fontsource-variable/lora": "^5.2.8",
		"@fontsource-variable/newsreader": "^5.2.10",
		"@fontsource-variable/source-serif-4": "^5.2.9",
		"@fontsource/atkinson-hyperlegible": "^5.2.8",
		"@minister/client": "git+https://github.com/MinistryofMany/minister-client.git#a009051",
		"@scure/bip39": "^1.5.0",
		"@semaphore-protocol/group": "^4.0.3",
		"@semaphore-protocol/identity": "^4.0.3",
		"@semaphore-protocol/proof": "^4.0.3",
		"@sentry/sveltekit": "^8.45.0",
		"@tiptap/core": "^3.0.0",
		"@tiptap/extension-image": "^3.0.0",
		"@tiptap/extension-link": "^3.0.0",
		"@tiptap/extension-typography": "^3.0.0",
		"@tiptap/pm": "^3.0.0",
		"@tiptap/starter-kit": "^3.0.0",
		"bits-ui": "^2.18.1",
		"dompurify": "^3.2.3",
		"drizzle-orm": "^0.45.2",
		"ethers": "^6.13.2",
		"isomorphic-dompurify": "^2.20.0",
		"jose": "^6.2.3",
		"marked": "^15.0.4",
		"nodemailer": "^9.0.1",
		"phosphor-svelte": "^3.1.0",
		"pino": "^9.5.0",
		"postgres": "^3.4.5",
		"sharp": "^0.33.5",
		"svelte-i18n": "^4.0.1",
		"tiptap-markdown": "^0.9.0",
		"uuid": "^11.1.1",
		"web-push": "^3.6.7",
		"zod": "^3.23.8"
	},
	"overrides": {
		"underscore": "^1.13.7",
		"esbuild": "^0.28.1",
		"snarkjs": "^0.7.6",
		"circomkit": "^0.3.4",
		"circom_tester": "^0.0.24"
	},
	"license": "AGPL-3.0-only",
	"author": "AtHeartEngineer"
}
