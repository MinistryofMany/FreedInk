# Postgres connection (used by app + drizzle-kit)
DATABASE_URL=postgres://freedink:freedink@localhost:5432/freedink

# Public-facing origin (used for SIWE domain + WebAuthn rpID/origin)
PUBLIC_ORIGIN=http://localhost:5173
PUBLIC_RP_ID=localhost
PUBLIC_RP_NAME=Freed Ink

# 32-byte hex, used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=replace_me_with_64_hex_chars

# Email magic-links (optional in dev: logs to console if unset)
SMTP_URL=
SMTP_FROM="Freed Ink <noreply@freed.ink>"

# Sentry observability (both optional — leave unset to skip Sentry entirely).
# SENTRY_DSN is the server-side DSN; never expose this in client bundles.
SENTRY_DSN=
# PUBLIC_SENTRY_DSN is the browser DSN; it is inlined into the client bundle,
# so use a DSN scoped to the browser project on Sentry.
PUBLIC_SENTRY_DSN=

# ── Service-operator allowlist (OPTIONAL) ────────────────────────────────────
#
# Comma-separated list of Minister OIDC subjects (`sub`) that get the global
# operator dashboard at /admin/ops: cross-blog access to every blog's Manage /
# Settings / Review / Posts moderation and the reports queue. FAILS CLOSED — if
# this is unset/empty there are NO operators and /admin/ops is inaccessible.
#
# Each value is a Minister pairwise subject. To find yours: sign in with
# Minister, open /admin/ops (once you're allowlisted) or your account — the ops
# overview surfaces your subject. On a fresh deploy where no one is yet an
# operator, read it from the FreedInk user row / oidc_identities table, set it
# here, and redeploy.
FREEDINK_OPERATOR_SUBS=

# Optional bearer token for the /metrics Prometheus endpoint. Leave unset to
# expose metrics openly (rely on network-layer restrictions, e.g. binding the
# scraper to a private subnet). When set, scrapers must send
# `Authorization: Bearer <value>` or they get 401.
METRICS_BEARER=

# ── Signet blind-signing service (OPTIONAL hardening add-on) ──────────────────
#
# Vote-token blind-signing backend. UNSET (the default) → FreedInk signs vote
# tokens IN-PROCESS with a per-blog key in blog_vote_token_keys (simple, less
# secure; fine for dev / low-stakes / self-hosters). SET → FreedInk routes signing
# to the external, hardened Signet service over mTLS, holding NO private key
# itself (the production-hardened path; the signer is also the per-(user,version)
# policy boundary a compromised FreedInk cannot bypass).
#
# The wire scheme is IDENTICAL either way (RSAPBSSA.SHA384.PSS.Randomized, public
# metadata freedink-vote:<versionId>), so tokens verify the same regardless of
# backend — switching backends is purely an env change, no code change.
#
# All four are required together to enable Signet; leaving SIGNET_URL unset keeps
# the local fallback. Setting SIGNET_URL WITHOUT the three cert vars fails loudly
# at startup (it never silently degrades to no-mTLS). Each cert var accepts either
# inline PEM or a filesystem path to a PEM file.
#
# SIGNET_URL          Base URL of the signer, e.g. https://signet:8443 (the
#                     hostname MUST match the server cert SAN; inside the
#                     network-isolated compose this is https://signet:8443).
# SIGNET_CLIENT_CERT  FreedInk's mTLS CLIENT certificate (PEM or path). Its CN/SAN
#                     must be on Signet's SIGNET_ALLOWED_CLIENT_IDS (dev: "freedink").
# SIGNET_CLIENT_KEY   The client certificate's private key (PEM or path).
# SIGNET_CA_CERT      CA that signed Signet's SERVER cert, used to verify it (PEM
#                     or path). For dev, this is Signet's deploy/certs/ca.pem.
SIGNET_URL=
SIGNET_CLIENT_CERT=
SIGNET_CLIENT_KEY=
SIGNET_CA_CERT=
